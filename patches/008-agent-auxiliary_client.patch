diff --git a/agent/auxiliary_client.py b/agent/auxiliary_client.py
index 89dc7d935..ca54358ba 100644
--- a/agent/auxiliary_client.py
+++ b/agent/auxiliary_client.py
@@ -3623,6 +3623,36 @@ def resolve_provider_client(
